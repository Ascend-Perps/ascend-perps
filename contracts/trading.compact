circuit hashRevokeEscrowMirror(
          bridgeDeploymentId: Bytes<32>,
          domain: Bytes<32>,
          accountId: Bytes<32>,
          chainId: Uint<8>,
          escrowRef: Bytes<32>,
          terminalEvidenceHash: Bytes<32>,
