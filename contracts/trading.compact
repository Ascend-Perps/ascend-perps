           [pad(32, "ascend:bridge:revoke"),
            bridgeDeploymentId,
            domain,
            accountId,
            chainId as Bytes<32>,
            escrowRef,
            terminalEvidenceHash,
            revokeNonce as Bytes<32>,]
           );
}

circuit hashCreateOrderOp(
          accountId: Bytes<32>,
          marketIndex: Uint<16>,
          price: Uint<32>,
          size: Uint<64>,
          isAsk: Boolean,
          orderType: Uint<8>,
          nonce: Uint<64>,
          orderExpiresAt: Uint<64>,
          ): Bytes<32> {
  const isAskU: Uint<8> = isAsk ? 1 as Uint<8> : 0 as Uint<8>;
  return persistentHash<Vector<9, Bytes<32>>>(
           [pad(32, "ascend:perps:createOrder"),
            accountId,
            marketIndex as Bytes<32>,
            price as Bytes<32>,
            size as Bytes<32>,
            isAskU as Bytes<32>,
            orderType as Bytes<32>,
            nonce as Bytes<32>,
            orderExpiresAt as Bytes<32>,]
           );
}

circuit hashCancelOrderOp(accountId: Bytes<32>, nonce: Uint<64>): Bytes<32> {
  return persistentHash<Vector<3, Bytes<32>>>(
           [pad(32, "ascend:perps:cancelOrder"), accountId, nonce as Bytes<32>,]
           );
}

circuit hashExecuteTradeAuthorization(
          takerAccountId: Bytes<32>,
          takerOrderNonce: Uint<64>,
          makerAccountId: Bytes<32>,
          makerOrderNonce: Uint<64>,
          marketIndex: Uint<16>,
          fillSize: Uint<64>,
          fillPrice: Uint<32>,
          executionNonce: Uint<64>,
          ): Bytes<32> {
  return persistentHash<Vector<9, Bytes<32>>>(
           [pad(32, "ascend:perps:executeTrade"),
            takerAccountId,
            takerOrderNonce as Bytes<32>,
            makerAccountId,
            makerOrderNonce as Bytes<32>,
            marketIndex as Bytes<32>,
            fillSize as Bytes<32>,
            fillPrice as Bytes<32>,
            executionNonce as Bytes<32>,]
           );
}

circuit hashPrivateBatchTransition(
          previousAccountRoot: Bytes<32>,
          nextAccountRoot: Bytes<32>,
          previousPositionRoot: Bytes<32>,
          nextPositionRoot: Bytes<32>,
          nextOrderCommitmentRoot: Bytes<32>,
          nextIntentNullifierRoot: Bytes<32>,
          nextBatchExecutionRoot: Bytes<32>,
          publicMarketDeltasRoot: Bytes<32>,
          proofCommitment: Bytes<32>,
          batchNonce: Uint<64>,
          ): Bytes<32> {
  return persistentHash<Vector<11, Bytes<32>>>(
           [pad(32, "ascend:private-batch:v2"),
            previousAccountRoot,
            nextAccountRoot,
            previousPositionRoot,
            nextPositionRoot,
            nextOrderCommitmentRoot,
            nextIntentNullifierRoot,
            nextBatchExecutionRoot,
            publicMarketDeltasRoot,
            proofCommitment,
            batchNonce as Bytes<32>,]
           );
}

export sealed ledger governorPk: Bytes<32>;

export sealed ledger sequencerPk: Bytes<32>;

export ledger attestorPk: VerifierKey;

export ledger creditCommittee: Map<Uint<8>, CommitteeKeys>;

export ledger creditDomainConfigs: Map<Uint<8>, CreditDomainConfig>;

export ledger pendingAttestorPk: PendingKey;

export ledger pendingAttestorActive: Boolean;

export ledger accountKeys: Map<Bytes<32>, VerifierKey>;

export ledger escrowMirrors: Map<Bytes<32>, EscrowMirror>;

export ledger creditedSourceEscrows: Map<Bytes<32>, Boolean>;

export ledger accountCollateralCap: Map<Bytes<32>, Uint<128>>;

export ledger accountCollateralExpiresAt: Map<Bytes<32>, Uint<64>>;

export ledger markets: Map<Uint<16>, MarketConfig>;

export ledger marketStates: Map<Uint<16>, MarketState>;

export ledger positions: Map<Bytes<32>, Position>;

export ledger orders: Map<Bytes<32>, Order>;

export ledger userNonceHwm: Map<Bytes<32>, Uint<64>>;

export ledger attestorReceiptHwm: Map<Bytes<32>, Uint<64>>;

export ledger executionNonceHwmByMarket: Map<Uint<16>, Uint<64>>;

export ledger revokeNonceHwm: Map<Bytes<32>, Uint<64>>;

export ledger openOrders: Map<Bytes<32>, Uint<32>>;

export ledger orderReservedQuote: Map<Bytes<32>, Uint<128>>;

export ledger accountUsedQuote: Map<Bytes<32>, Uint<128>>;

export ledger accountStateRoot: Bytes<32>;

export ledger positionStateRoot: Bytes<32>;

export ledger orderCommitmentRoot: Bytes<32>;

export ledger intentNullifierRoot: Bytes<32>;

export ledger batchExecutionRoot: Bytes<32>;

export ledger publicMarketDeltasRoot: Bytes<32>;

export ledger privateBatchProofCommitment: Bytes<32>;

export ledger privateBatchNonceHwm: Uint<64>;

export ledger pausedTrading: Boolean;

export sealed ledger bridgeDeploymentId: Bytes<32>;

constructor(initGovPk: Bytes<32>, initSeqPk: Bytes<32>, initAttestorX: Field, initAttestorY: Field, initBridgeDeploymentId: Bytes<32>,) {
  assert(initGovPk != pad(32, ""), "governor pk zero");
  assert(initSeqPk != pad(32, ""), "sequencer pk zero");
  assert(initAttestorX != 0 || initAttestorY != 0, "attestor pk zero");
  assert(initBridgeDeploymentId != pad(32, ""), "bridge deployment id zero");
  governorPk = disclose(initGovPk);
  sequencerPk = disclose(initSeqPk);
  attestorPk = disclose(VerifierKey { x: initAttestorX, y: initAttestorY });
  bridgeDeploymentId = disclose(initBridgeDeploymentId);
  accountStateRoot = disclose(pad(32, ""));
  positionStateRoot = disclose(pad(32, ""));
  orderCommitmentRoot = disclose(pad(32, ""));
  intentNullifierRoot = disclose(pad(32, ""));
  batchExecutionRoot = disclose(pad(32, ""));
  publicMarketDeltasRoot = disclose(pad(32, ""));
  privateBatchProofCommitment = disclose(pad(32, ""));
  privateBatchNonceHwm = disclose(0 as Uint<64>);
  pendingAttestorActive = disclose(false);
  pausedTrading = disclose(false);
}

export circuit submitBatch(
                 previousAccountRoot: Bytes<32>,
                 nextAccountRoot: Bytes<32>,
                 previousPositionRoot: Bytes<32>,
                 nextPositionRoot: Bytes<32>,
                 nextOrderCommitmentRoot: Bytes<32>,
                 nextIntentNullifierRoot: Bytes<32>,
                 nextBatchExecutionRoot: Bytes<32>,
                 nextPublicMarketDeltasRoot: Bytes<32>,
                 proofCommitment: Bytes<32>,
                 batchNonce: Uint<64>,
                 ): [] {
  requireSequencer();
  assert(!pausedTrading, "Trading paused");

  const dPreviousAccountRoot = disclose(previousAccountRoot);
  const dNextAccountRoot = disclose(nextAccountRoot);
  const dPreviousPositionRoot = disclose(previousPositionRoot);
  const dNextPositionRoot = disclose(nextPositionRoot);
  const dNextOrderCommitmentRoot = disclose(nextOrderCommitmentRoot);
  const dNextIntentNullifierRoot = disclose(nextIntentNullifierRoot);
  const dNextBatchExecutionRoot = disclose(nextBatchExecutionRoot);
  const dNextPublicMarketDeltasRoot = disclose(nextPublicMarketDeltasRoot);
  const dProofCommitment = disclose(proofCommitment);
  const dBatchNonce = disclose(batchNonce);

  assert(dPreviousAccountRoot == accountStateRoot, "account root mismatch");
  assert(dPreviousPositionRoot == positionStateRoot, "position root mismatch");
  assert(dNextAccountRoot != pad(32, ""), "next account root required");
  assert(dNextPositionRoot != pad(32, ""), "next position root required");
  assert(dNextOrderCommitmentRoot != pad(32, ""), "next order root required");
  assert(dNextIntentNullifierRoot != pad(32, ""), "next nullifier root required");
  assert(dNextBatchExecutionRoot != pad(32, ""), "next batch root required");
  assert(dProofCommitment != pad(32, ""), "proof commitment required");
  assert(dBatchNonce > privateBatchNonceHwm, "batch nonce not increasing");

  const transition = disclose(
                       hashPrivateBatchTransition(
                         dPreviousAccountRoot,
                         dNextAccountRoot,
                         dPreviousPositionRoot,
                         dNextPositionRoot,
                         dNextOrderCommitmentRoot,
                         dNextIntentNullifierRoot,
                         dNextBatchExecutionRoot,
                         dNextPublicMarketDeltasRoot,
                         dProofCommitment,
                         dBatchNonce,
                         )
                       );
  assert(transition != pad(32, ""), "private batch transition invalid");

  accountStateRoot = dNextAccountRoot;
  positionStateRoot = dNextPositionRoot;
  orderCommitmentRoot = dNextOrderCommitmentRoot;
  intentNullifierRoot = dNextIntentNullifierRoot;
  batchExecutionRoot = dNextBatchExecutionRoot;
  publicMarketDeltasRoot = dNextPublicMarketDeltasRoot;
  privateBatchProofCommitment = dProofCommitment;
  privateBatchNonceHwm = dBatchNonce;
}

export circuit setCreditCommittee(chainId: Uint<8>, keys: CommitteeKeys): [] {
  requireGovernor();
  const dChain = disclose(chainId);
  assertSupportedSourceChain(dChain);
  const dKeys = disclose(keys);
  assertCommitteeDistinct(dKeys);
  creditCommittee.insert(dChain, dKeys);
}

export circuit setCreditDomain(
                 chainId: Uint<8>,
                 domain: Bytes<32>,
                 sourceContractId: Bytes<32>,
                 targetChainId: Uint<8>,
                 targetContractId: Bytes<32>,
                 committeeEpoch: Uint<64>,
                 ): [] {
  requireGovernor();
  const dChain = disclose(chainId);
  assertSupportedSourceChain(dChain);
  const dSourceContractId = disclose(sourceContractId);
  const dTargetContractId = disclose(targetContractId);
  const dCommitteeEpoch = disclose(committeeEpoch);
  assert(dSourceContractId != pad(32, ""), "source contract id required");
  assert(dTargetContractId != pad(32, ""), "target contract id required");
  assert(dCommitteeEpoch > 0 as Uint<64>, "Committee epoch must be positive");
  const expectedDomain =
          disclose(hashDomainTupleV2(
                     bridgeDeploymentId,
                     dChain,
                     dSourceContractId,
                     disclose(targetChainId),
                     dTargetContractId,
                     dCommitteeEpoch,
                     ));
  assert(disclose(domain) == expectedDomain, "domain does not match DomainTuple");
  creditDomainConfigs.insert(
    dChain,
    disclose(CreditDomainConfig { chainId: chainId,
                                  enabled: true,
                                  domain: expectedDomain,
                                  sourceContractId: dSourceContractId,
                                  targetChainId: targetChainId,
                                  targetContractId: dTargetContractId,
                                  committeeEpoch: dCommitteeEpoch, })
    );
}

export circuit registerAccount(
                 accountId: Bytes<32>,
                 chainId: Uint<8>,
                 escrowRef: Bytes<32>,
                 clawbackAuthHash: Bytes<32>,
                 cap: Uint<128>,
                 expiresAt: Uint<64>,
                 terminalEvidenceHash: Bytes<32>,
                 nonce: Uint<64>,
                 userPkX: Field,
                 userPkY: Field,
                 userSig: SchnorrSignature,
                 receiptNonce: Uint<64>,
                 attestorSigs: Vector<3, SchnorrSignature>,
                 ): [] {
  requireSequencer();
  assert(!pausedTrading, "Trading paused");

  const dAccountId = disclose(accountId);
  const dChain = disclose(chainId);
  const creditDomain = assertCreditDomainCurrent(dChain);
  const dPkX = disclose(userPkX);
  const dPkY = disclose(userPkY);
  assert(dPkX != 0 || dPkY != 0, "user pk zero");
  assert(dAccountId == accountIdForUserKey(dPkX, dPkY), "accountId/user key mismatch");
  const dTerminalEvidenceHash = disclose(terminalEvidenceHash);
  assert(dTerminalEvidenceHash != pad(32, ""), "terminal evidence hash required");

  const dNonce = disclose(nonce);
  assertAndBumpHwm(pad(32, "trading:user-reg"), dAccountId, dNonce);

  if (accountKeys.member(dAccountId)) {
    const existing = accountKeys.lookup(dAccountId);
    assert(existing.x == dPkX, "Account key x mismatch");
    assert(existing.y == dPkY, "Account key y mismatch");
  } else {
    accountKeys.insert(dAccountId, VerifierKey { x: dPkX, y: dPkY });
  }

  const userKey = VerifierKey { x: dPkX, y: dPkY };
  const userMsg = degradeToTransient(
                    hashRegisterIntent(
                      bridgeDeploymentId,
                      creditDomain,
                      dAccountId,
                      dChain,
                      disclose(escrowRef),
                      disclose(clawbackAuthHash),
                      disclose(cap),
                      disclose(expiresAt),
                      dTerminalEvidenceHash,
                      dPkX,
                      dPkY,
                      dNonce,
                      )
                    );
  verifySchnorr(userSig, userKey, userMsg);

  const activatedEscrowHash =
          disclose(hashActivatedEscrowForReceipt(
                     bridgeDeploymentId,
                     creditDomain,
                     dChain,
                     disclose(escrowRef),
                     disclose(clawbackAuthHash),
                     disclose(cap),
                     disclose(expiresAt),
                     dTerminalEvidenceHash,
                     ));

  const dReceiptNonce = disclose(receiptNonce);
  assertAndBumpReceiptHwm(dAccountId, dReceiptNonce);

  const receiptHash =
          hashActivatedBindReceipt(
            bridgeDeploymentId,
            creditDomain,
            dAccountId,
            dChain,
            activatedEscrowHash,
            disclose(expiresAt),
            dReceiptNonce,
            );
  assert(creditCommittee.member(dChain), "Credit committee not set for chain");
  verifyCommitteeQuorum(attestorSigs, creditCommittee.lookup(dChain), degradeToTransient(receiptHash));
  addMirroredCollateral(
    dAccountId,
    dChain,
    disclose(escrowRef),
    activatedEscrowHash,
    dTerminalEvidenceHash,
    disclose(cap),
    disclose(expiresAt),
  );
  assertAccountUsageWithinCap(dAccountId, accountCollateralCap.lookup(dAccountId));
}

export circuit refreshEscrowMirror(
                 accountId: Bytes<32>,
                 chainId: Uint<8>,
                 escrowRef: Bytes<32>,
                 clawbackAuthHash: Bytes<32>,
                 cap: Uint<128>,
                 expiresAt: Uint<64>,
                 terminalEvidenceHash: Bytes<32>,
                 receiptNonce: Uint<64>,
                 attestorSigs: Vector<3, SchnorrSignature>,
                 ): [] {
  requireSequencer();
  const dAccountId = disclose(accountId);
  const dChainR = disclose(chainId);
  const creditDomain = assertCreditDomainCurrent(dChainR);
  assert(accountKeys.member(dAccountId), "Account not registered");
  const dTerminalEvidenceHash = disclose(terminalEvidenceHash);
  assert(dTerminalEvidenceHash != pad(32, ""), "terminal evidence hash required");

  const activatedEscrowHash =
          disclose(hashActivatedEscrowForReceipt(
                     bridgeDeploymentId,
                     creditDomain,
                     dChainR,
                     disclose(escrowRef),
                     disclose(clawbackAuthHash),
                     disclose(cap),
                     disclose(expiresAt),
                     dTerminalEvidenceHash,
                     ));

  const dReceiptNonce = disclose(receiptNonce);
  assertAndBumpReceiptHwm(dAccountId, dReceiptNonce);

  const receiptHash =
          hashActivatedBindReceipt(
            bridgeDeploymentId,
            creditDomain,
            dAccountId,
            dChainR,
            activatedEscrowHash,
            disclose(expiresAt),
            dReceiptNonce,
            );
  assert(creditCommittee.member(dChainR), "Credit committee not set for chain");
  verifyCommitteeQuorum(attestorSigs, creditCommittee.lookup(dChainR), degradeToTransient(receiptHash));
  addMirroredCollateral(
    dAccountId,
    dChainR,
    disclose(escrowRef),
    activatedEscrowHash,
    dTerminalEvidenceHash,
    disclose(cap),
    disclose(expiresAt),
  );
  assertAccountUsageWithinCap(dAccountId, accountCollateralCap.lookup(dAccountId));
}

export circuit revokeEscrowMirror(
                 accountId: Bytes<32>,
                 chainId: Uint<8>,
                 escrowRef: Bytes<32>,
                 terminalEvidenceHash: Bytes<32>,
                 revokeNonce: Uint<64>,
                 attestorSig: SchnorrSignature,
): [] {
  requireSequencer();
  const dAccountId = disclose(accountId);
  const dChain = disclose(chainId);
  const creditDomain = assertCreditDomainCurrent(dChain);
  const dEscrowRef = disclose(escrowRef);
  const dTerminalEvidenceHash = disclose(terminalEvidenceHash);
  assert(dTerminalEvidenceHash != pad(32, ""), "terminal evidence hash required");
  const mirrorKey = disclose(escrowMirrorStateKey(dAccountId, dChain, dEscrowRef, dTerminalEvidenceHash));
  assert(escrowMirrors.member(mirrorKey), "Escrow mirror not active");
  const mirror = escrowMirrors.lookup(mirrorKey);
  const nowTs = nowBounded();
  const expired = (mirror.expiresAt + 604800 as Uint<64>) as Uint<64> < nowTs;
  if (!expired) {
    const dRevokeNonce = disclose(revokeNonce);
    const currentRevokeNonce =
            revokeNonceHwm.member(dAccountId) ? revokeNonceHwm.lookup(dAccountId) : 0 as Uint<64>;
    assert(dRevokeNonce > currentRevokeNonce, "Revoke nonce must be strictly increasing");

    const revokeHash =
            hashRevokeEscrowMirror(
              bridgeDeploymentId,
              creditDomain,
              dAccountId,
              dChain,
              dEscrowRef,
              dTerminalEvidenceHash,
              dRevokeNonce,
              );
    verifySchnorr(attestorSig, attestorPk, degradeToTransient(revokeHash));
    revokeNonceHwm.insert(dAccountId, dRevokeNonce);
  }

  const currentCap =
          accountCollateralCap.member(dAccountId)
            ? accountCollateralCap.lookup(dAccountId)
            : 0 as Uint<128>;
  assert(currentCap >= mirror.cap, "Account collateral cap underflow");
  const nextCap = (currentCap - mirror.cap) as Uint<128>;
  assertAccountUsageWithinCap(dAccountId, nextCap);
  if (nextCap == 0 as Uint<128>) {
    accountCollateralCap.remove(dAccountId);
    accountCollateralExpiresAt.remove(dAccountId);
  } else {
    accountCollateralCap.insert(dAccountId, nextCap);
  }
  escrowMirrors.remove(mirrorKey);
  const sourceKey = disclose(sourceEscrowCreditKey(dChain, dEscrowRef));
  if (creditedSourceEscrows.member(sourceKey)) {
    creditedSourceEscrows.remove(sourceKey);
  }
}

export circuit syncMarket(
                 marketIndex: Uint<16>,
                 status: Uint<8>,
                 takerFee: Uint<32>,
                 makerFee: Uint<32>,
                 liquidationFee: Uint<32>,
                 defaultIMF: Uint<16>,
                 minIMF: Uint<16>,
                 maintenanceMF: Uint<16>,
                 closeOutMF: Uint<16>,
                 quoteMultiplier: Uint<32>,
                 interestRate: Uint<32>,
                 fundingClampSmall: Uint<32>,
                 fundingClampBig: Uint<32>,
                 openInterestLimit: Uint<64>,
                 minBaseAmount: Uint<64>,
                 markPrice: Uint<32>,
                 indexPrice: Uint<32>,
                 ): [] {
  requireGovernor();
  const dIdx = disclose(marketIndex);
  assert(dIdx < 128 as Uint<16>, "market index out of range");
  markets.insert(
    dIdx,
    disclose(MarketConfig { marketIndex: marketIndex,
                            status: status,
                            takerFee: takerFee,
                            makerFee: makerFee,
                            liquidationFee: liquidationFee,
                            defaultIMF: defaultIMF,
                            minIMF: minIMF,
                            maintenanceMF: maintenanceMF,
                            closeOutMF: closeOutMF,
                            quoteMultiplier: quoteMultiplier,
                            interestRate: interestRate,
                            fundingClampSmall: fundingClampSmall,
                            fundingClampBig: fundingClampBig,
                            openInterestLimit: openInterestLimit,
                            minBaseAmount: minBaseAmount, })
    );
  const dMark = disclose(markPrice);
  const dIndex = disclose(indexPrice);
  assert(dMark >= 1, "Mark price too low");
  assert(dIndex >= 1, "Index price too low");
  if (marketStates.member(dIdx)) {
    const st = marketStates.lookup(dIdx);
    marketStates.insert(
      dIdx,
      disclose(MarketState { markPrice: markPrice,
                             indexPrice: indexPrice,
                             openInterest: st.openInterest,
                             fundingIndex: st.fundingIndex,
                             fundingIsNeg: st.fundingIsNeg,
                             lastFundingTs: st.lastFundingTs,
                             totalVolume: st.totalVolume, })
      );
  } else {
    marketStates.insert(
      dIdx,
      disclose(MarketState { markPrice: markPrice,
                             indexPrice: indexPrice,
                             openInterest: 0 as Uint<64>,
                             fundingIndex: 0 as Uint<128>,
                             fundingIsNeg: false,
                             lastFundingTs: 0 as Uint<64>,
                             totalVolume: 0 as Uint<128>, })
      );
  }
}

export circuit createOrder(
                 accountId: Bytes<32>,
                 marketIndex: Uint<16>,
                 price: Uint<32>,
                 size: Uint<64>,
                 isAsk: Boolean,
                 orderType: Uint<8>,
                 nonce: Uint<64>,
                 orderExpiresAt: Uint<64>,
                 userSig: SchnorrSignature,
                 ): [] {
  requireSequencer();
  assert(!pausedTrading, "Trading paused");

  const dAccountId = disclose(accountId);
  const dIdx = disclose(marketIndex);
  assert(markets.member(dIdx), "Market not found");
  const cfg = markets.lookup(dIdx);
  assert(cfg.status == 1, "Market not active");

  assert(accountKeys.member(dAccountId), "Account has no registered key");
  const nowTs = nowBounded();
  const collateral = assertActiveAccountCollateral(dAccountId, nowTs);

  const dExp = disclose(orderExpiresAt);
  assert(dExp > nowTs, "orderExpiresAt must be in the future");
  assert(dExp <= collateral.expiresAt, "orderExpiresAt exceeds escrow window");
  const dOrderType = disclose(orderType);
  assert(dOrderType == 0 as Uint<8>, "Unsupported order type");

  const userKey = accountKeys.lookup(dAccountId);
  const msgHash = degradeToTransient(
                    hashCreateOrderOp(
                      dAccountId,
                      dIdx,
                      disclose(price),
                      disclose(size),
                      disclose(isAsk),
                      dOrderType,
                      disclose(nonce),
                      dExp,
                      )
                    );
  verifySchnorr(userSig, userKey, msgHash);

  const dSize = disclose(size);
  assert(dSize >= cfg.minBaseAmount, "Size below minimum");
  const dPrice = disclose(price);
  assert(dPrice >= 1, "Price must be positive");
  const reservedQuote = notionalQuote(dSize, dPrice);
  addAccountUsage(dAccountId, reservedQuote, collateral.cap);

  assertAndBumpHwm(pad(32, "trading:user"), dAccountId, disclose(nonce));

  const currentOpen = openOrders.member(dAccountId) ? openOrders.lookup(dAccountId) : 0 as Uint<32>;
  assert(currentOpen < 64 as Uint<32>, "Open-order cap exceeded (64 per account)");
  openOrders.insert(dAccountId, disclose((currentOpen + 1) as Uint<32>));

  const ok = disclose(orderKey(dAccountId, nonce));
  orderReservedQuote.insert(ok, reservedQuote);
  orders.insert(
    ok,
    disclose(Order { accountId: accountId,
                     marketIndex: marketIndex,
                     price: price,
                     size: size,
                     remainingSize: size,
                     isAsk: isAsk,
                     orderType: orderType,
                     expiresAt: orderExpiresAt, })
    );
}

export circuit cancelOrder(accountId: Bytes<32>, nonce: Uint<64>, userSig: SchnorrSignature,): [] {
  requireSequencer();

  const dAccountId = disclose(accountId);
  assert(accountKeys.member(dAccountId), "Account has no registered key");
  const userKey = accountKeys.lookup(dAccountId);
  const msgHash = degradeToTransient(hashCancelOrderOp(dAccountId, disclose(nonce)));
  verifySchnorr(userSig, userKey, msgHash);

  const ok = disclose(orderKey(dAccountId, nonce));
  assert(orders.member(ok), "Order not found");
  const order = orders.lookup(ok);
  assert(order.accountId == dAccountId, "Not order owner");
  assert(orderReservedQuote.member(ok), "Order reserved quote missing");
  const reservedQuote = orderReservedQuote.lookup(ok);
  orderReservedQuote.remove(ok);
  releaseOrderUsage(dAccountId, reservedQuote);

  const currentOpen = openOrders.member(dAccountId) ? openOrders.lookup(dAccountId) : 0 as Uint<32>;
  assert(currentOpen >= 1 as Uint<32>, "openOrders counter underflow");
  openOrders.insert(dAccountId, disclose((currentOpen - 1) as Uint<32>));

  orders.remove(ok);
}

export circuit executeTrade(
                 takerAccountId: Bytes<32>,
                 takerOrderNonce: Uint<64>,
                 makerAccountId: Bytes<32>,
                 makerOrderNonce: Uint<64>,
                 marketIndex: Uint<16>,
                 fillSize: Uint<64>,
                 fillPrice: Uint<32>,
                 executionNonce: Uint<64>,
                 attestorSig: SchnorrSignature,
                 ): [] {
  requireSequencer();
  assert(!pausedTrading, "Trading paused");

  const dIdx = disclose(marketIndex);
  assert(markets.member(dIdx), "Market not found");
  const cfg = markets.lookup(dIdx);
  assert(cfg.status == 1, "Market not active");
  const st = marketStates.lookup(dIdx);

  const dFillSize = disclose(fillSize);
  const dFillPrice = disclose(fillPrice);
  const dExecutionNonce = disclose(executionNonce);
  assert(dFillSize >= cfg.minBaseAmount, "Fill below minimum");
  assert(dFillPrice >= 1, "Price must be positive");

  const dTaker = disclose(takerAccountId);
  const dMaker = disclose(makerAccountId);
  assert(dTaker != dMaker, "Self-trade disabled");
  const dTakerNonce = disclose(takerOrderNonce);
  const dMakerNonce = disclose(makerOrderNonce);

  const takerOrderK = disclose(orderKey(dTaker, dTakerNonce));
  const makerOrderK = disclose(orderKey(dMaker, dMakerNonce));
  assert(orders.member(takerOrderK), "Taker order not found");
  assert(orders.member(makerOrderK), "Maker order not found");
  const takerOrder = orders.lookup(takerOrderK);
  const makerOrder = orders.lookup(makerOrderK);
  assert(takerOrder.accountId == dTaker, "Taker order ownership mismatch");
  assert(makerOrder.accountId == dMaker, "Maker order ownership mismatch");
  assert(takerOrder.marketIndex == marketIndex, "Taker market mismatch");
  assert(makerOrder.marketIndex == marketIndex, "Maker market mismatch");
  assert(takerOrder.isAsk != makerOrder.isAsk, "Same-side fill");
  assert(takerOrder.remainingSize >= fillSize, "Taker insufficient remaining");
  assert(makerOrder.remainingSize >= fillSize, "Maker insufficient remaining");

  const nowTs = nowBounded();
  assert(nowTs < takerOrder.expiresAt, "Taker order expired");
  assert(nowTs < makerOrder.expiresAt, "Maker order expired");

  const takerCollateral = assertActiveAccountCollateral(dTaker, nowTs);
  const makerCollateral = assertActiveAccountCollateral(dMaker, nowTs);
  assert(dFillPrice == makerOrder.price, "Fill price must equal maker price");
  if (takerOrder.isAsk) {
    assert(makerOrder.price >= takerOrder.price, "Taker ask not crossed");
  } else {
    assert(makerOrder.price <= takerOrder.price, "Taker bid not crossed");
  }

  const executionHash =
          hashExecuteTradeAuthorization(
            dTaker,
            dTakerNonce,
            dMaker,
            dMakerNonce,
            dIdx,
            dFillSize,
            dFillPrice,
            dExecutionNonce,
            );
  const currentExecutionNonce =
          executionNonceHwmByMarket.member(dIdx)
            ? executionNonceHwmByMarket.lookup(dIdx)
            : 0 as Uint<64>;
  assert(dExecutionNonce > currentExecutionNonce, "Execution nonce must be strictly increasing");
  verifySchnorr(attestorSig, attestorPk, degradeToTransient(executionHash));
  executionNonceHwmByMarket.insert(dIdx, dExecutionNonce);

  const newTakerRemaining = (takerOrder.remainingSize - dFillSize) as Uint<64>;
  const newMakerRemaining = (makerOrder.remainingSize - dFillSize) as Uint<64>;
  const tradeQuote = notionalQuote(dFillSize, dFillPrice);
  assert(orderReservedQuote.member(takerOrderK), "Taker reserved quote missing");
  assert(orderReservedQuote.member(makerOrderK), "Maker reserved quote missing");
  const takerReserved = orderReservedQuote.lookup(takerOrderK);
  const makerReserved = orderReservedQuote.lookup(makerOrderK);
  assert(takerReserved >= tradeQuote, "Taker reserved quote underflow");
  assert(makerReserved >= tradeQuote, "Maker reserved quote underflow");

  if (newTakerRemaining == 0 as Uint<64>) {
    orders.remove(takerOrderK);
    orderReservedQuote.remove(takerOrderK);
    const takerOpen = openOrders.member(dTaker) ? openOrders.lookup(dTaker) : 0 as Uint<32>;
    assert(takerOpen >= 1 as Uint<32>, "taker openOrders underflow");
    openOrders.insert(dTaker, disclose((takerOpen - 1) as Uint<32>));
  } else {
    orderReservedQuote.insert(takerOrderK, disclose((takerReserved - tradeQuote) as Uint<128>));
    orders.insert(
      takerOrderK,
      disclose(Order { accountId: takerOrder.accountId,
                       marketIndex: takerOrder.marketIndex,
                       price: takerOrder.price,
                       size: takerOrder.size,
                       remainingSize: newTakerRemaining,
                       isAsk: takerOrder.isAsk,
                       orderType: takerOrder.orderType,
                       expiresAt: takerOrder.expiresAt, })
      );
  }

  if (newMakerRemaining == 0 as Uint<64>) {
    orders.remove(makerOrderK);
    orderReservedQuote.remove(makerOrderK);
    const makerOpen = openOrders.member(dMaker) ? openOrders.lookup(dMaker) : 0 as Uint<32>;
    assert(makerOpen >= 1 as Uint<32>, "maker openOrders underflow");
    openOrders.insert(dMaker, disclose((makerOpen - 1) as Uint<32>));
  } else {
    orderReservedQuote.insert(makerOrderK, disclose((makerReserved - tradeQuote) as Uint<128>));
    orders.insert(
      makerOrderK,
      disclose(Order { accountId: makerOrder.accountId,
                       marketIndex: makerOrder.marketIndex,
                       price: makerOrder.price,
                       size: makerOrder.size,
                       remainingSize: newMakerRemaining,
                       isAsk: makerOrder.isAsk,
                       orderType: makerOrder.orderType,
                       expiresAt: makerOrder.expiresAt, })
      );
  }

  const takerIsLong = !takerOrder.isAsk;
  const makerIsLong = !makerOrder.isAsk;

  const takerPosKey = disclose(positionKey(dTaker, dIdx));
  const oldTaker =
          positions.member(takerPosKey)
            ? positions.lookup(takerPosKey)
            : Position { size: 0 as Uint<64>,
                         isLong: false,
                         entryPrice: 0 as Uint<64>,
                         entryQuote: 0 as Uint<128>,
                         lastFundingIndex: 0 as Uint<128>,
                         lastFundingIsNeg: false, };
  const newTaker = applyFillToPosition(oldTaker, dFillSize, dFillPrice, takerIsLong, st);
  replaceAccountPositionUsage(dTaker, tradeQuote, oldTaker.entryQuote, newTaker.entryQuote, takerCollateral.cap);
  if (disclose(newTaker.size == 0 as Uint<64>)) {
    if (positions.member(takerPosKey)) {
      positions.remove(takerPosKey);
    }
  } else {
    positions.insert(takerPosKey, disclose(newTaker));
  }

  const makerPosKey = disclose(positionKey(dMaker, dIdx));
  const oldMaker =
          positions.member(makerPosKey)
            ? positions.lookup(makerPosKey)
            : Position { size: 0 as Uint<64>,
                         isLong: false,
                         entryPrice: 0 as Uint<64>,
                         entryQuote: 0 as Uint<128>,
                         lastFundingIndex: 0 as Uint<128>,
                         lastFundingIsNeg: false, };
  const newMaker = applyFillToPosition(oldMaker, dFillSize, dFillPrice, makerIsLong, st);
  replaceAccountPositionUsage(dMaker, tradeQuote, oldMaker.entryQuote, newMaker.entryQuote, makerCollateral.cap);
  if (disclose(newMaker.size == 0 as Uint<64>)) {
    if (positions.member(makerPosKey)) {
      positions.remove(makerPosKey);
    }
  } else {
    positions.insert(makerPosKey, disclose(newMaker));
  }

  const oldTakerLong = oldTaker.isLong ? oldTaker.size : 0 as Uint<64>;
  const newTakerLong = newTaker.isLong ? newTaker.size : 0 as Uint<64>;
  const oldMakerLong = oldMaker.isLong ? oldMaker.size : 0 as Uint<64>;
  const newMakerLong = newMaker.isLong ? newMaker.size : 0 as Uint<64>;
  const takerLongUp =
          newTakerLong >= oldTakerLong ? (newTakerLong - oldTakerLong) as Uint<64> : 0 as Uint<64>;
  const takerLongDown =
          oldTakerLong >= newTakerLong ? (oldTakerLong - newTakerLong) as Uint<64> : 0 as Uint<64>;
  const makerLongUp =
          newMakerLong >= oldMakerLong ? (newMakerLong - oldMakerLong) as Uint<64> : 0 as Uint<64>;
  const makerLongDown =
          oldMakerLong >= newMakerLong ? (oldMakerLong - newMakerLong) as Uint<64> : 0 as Uint<64>;
  const oiAfterUp = (st.openInterest + takerLongUp + makerLongUp) as Uint<64>;
  const oiDown = (takerLongDown + makerLongDown) as Uint<64>;
  const newOi = oiAfterUp >= oiDown ? (oiAfterUp - oiDown) as Uint<64> : 0 as Uint<64>;

  assert(newOi <= cfg.openInterestLimit, "OI cap exceeded");

  marketStates.insert(
    dIdx,
    disclose(MarketState { markPrice: st.markPrice,
                           indexPrice: st.indexPrice,
                           openInterest: newOi,
                           fundingIndex: st.fundingIndex,
                           fundingIsNeg: st.fundingIsNeg,
                           lastFundingTs: st.lastFundingTs,
                           totalVolume: (st.totalVolume + tradeQuote) as Uint<128>, })
    );
}

export circuit pruneOrder(accountId: Bytes<32>, orderNonce: Uint<64>,): [] {
  requireSequencer();

  const dAccountId = disclose(accountId);
  const dOrderNonce = disclose(orderNonce);

  const ok = disclose(orderKey(dAccountId, dOrderNonce));
  assert(orders.member(ok), "Order not found");
  const order = orders.lookup(ok);
  assert(order.accountId == dAccountId, "Not order owner");
  assert(orderReservedQuote.member(ok), "Order reserved quote missing");
  const reservedQuote = orderReservedQuote.lookup(ok);
  orderReservedQuote.remove(ok);
  releaseOrderUsage(dAccountId, reservedQuote);

  const nowTs = nowBounded();
  assert(order.expiresAt <= nowTs, "Order not yet expired");

  const currentOpen = openOrders.member(dAccountId) ? openOrders.lookup(dAccountId) : 0 as Uint<32>;
  assert(currentOpen >= 1 as Uint<32>, "openOrders counter underflow");
  openOrders.insert(dAccountId, disclose((currentOpen - 1) as Uint<32>));

  orders.remove(ok);
}

export circuit setPausedTrading(p: Boolean): [] {
  requireGovernor();
  pausedTrading = disclose(p);
}

export circuit proposeAttestorKey(newX: Field, newY: Field): [] {
  requireGovernor();
  assert(newX != 0 || newY != 0, "attestor pk zero");
  const nowTs = nowBounded();
  pendingAttestorPk =
    disclose(PendingKey { x: newX, y: newY, effective: (nowTs + 86400 as Uint<64>) as Uint<64>, });
  pendingAttestorActive = disclose(true);
}

export circuit activateAttestorKey(): [] {
  requireGovernor();
  assert(pendingAttestorActive, "No pending attestor key");
  assert(blockTimeGte(pendingAttestorPk.effective), "Timelock not elapsed");
  attestorPk = VerifierKey { x: pendingAttestorPk.x, y: pendingAttestorPk.y };
  pendingAttestorActive = disclose(false);
}
