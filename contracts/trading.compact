pragma language_version >= 0.23;

import CompactStandardLibrary;

struct VerifierKey {
  x: Field;
  y: Field;
}

struct SchnorrSignature {
  rX: Field;
  rY: Field;
  s: Field;
  h: Field;
  hQuotient: Uint<8>;
}

struct PendingKey {
  x: Field;
  y: Field;
  effective: Uint<64>;
}

struct MarketConfig {
  marketIndex: Uint<16>;
  status: Uint<8>;
  takerFee: Uint<32>;
  makerFee: Uint<32>;
  liquidationFee: Uint<32>;
  defaultIMF: Uint<16>;
  minIMF: Uint<16>;
  maintenanceMF: Uint<16>;
  closeOutMF: Uint<16>;
  quoteMultiplier: Uint<32>;
  interestRate: Uint<32>;
  fundingClampSmall: Uint<32>;
  fundingClampBig: Uint<32>;
  openInterestLimit: Uint<64>;
  minBaseAmount: Uint<64>;
}

struct MarketState {
  markPrice: Uint<32>;
  indexPrice: Uint<32>;
  openInterest: Uint<64>;
  fundingIndex: Uint<128>;
  fundingIsNeg: Boolean;
  lastFundingTs: Uint<64>;
  totalVolume: Uint<128>;
}

struct Position {
  size: Uint<64>;
  isLong: Boolean;
  entryPrice: Uint<64>;
  entryQuote: Uint<128>;
  lastFundingIndex: Uint<128>;
  lastFundingIsNeg: Boolean;
}

struct Order {
  accountId: Bytes<32>;
  marketIndex: Uint<16>;
  price: Uint<32>;
  size: Uint<64>;
  remainingSize: Uint<64>;
  isAsk: Boolean;
  orderType: Uint<8>;
  expiresAt: Uint<64>;
}

struct EscrowMirror {
  chainId: Uint<8>;
  escrowRef: Bytes<32>;
  activatedEscrowHash: Bytes<32>;
  terminalEvidenceHash: Bytes<32>;
  cap: Uint<128>;
  expiresAt: Uint<64>;
}

struct AccountCollateral {
  cap: Uint<128>;
  expiresAt: Uint<64>;
}

struct CreditDomainConfig {
  chainId: Uint<8>;
  enabled: Boolean;
  domain: Bytes<32>;
  sourceContractId: Bytes<32>;
  targetChainId: Uint<8>;
  targetContractId: Bytes<32>;
  committeeEpoch: Uint<64>;
}

struct CommitteeKeys {
  slot0: VerifierKey;
  slot1: VerifierKey;
  slot2: VerifierKey;
  slot3: VerifierKey;
  slot4: VerifierKey;
  slotCount: Uint<8>;
}

witness committeeSlotChoice0(): Uint<8>;
witness committeeSlotChoice1(): Uint<8>;
witness committeeSlotChoice2(): Uint<8>;

witness sequencerSecret(): Maybe<Bytes<32>>;

witness governorSecret(): Maybe<Bytes<32>>;

witness currentTime(): Uint<64>;

struct DivResult { q: Uint<128>, r: Uint<128> }
witness reduceQuoteDiv(num: Field, den: Field): DivResult;

circuit hashSignerPk(sk: Bytes<32>, domain: Bytes<32>): Bytes<32> {
  return persistentHash<Vector<2, Bytes<32>>>([domain, sk]);
}

circuit requireSequencer(): [] {
  const k = sequencerSecret();
  assert(k.is_some, "No sequencer secret");
  const pk = disclose(hashSignerPk(k.value, pad(32, "ascend:sequencer:v1")));
  assert(pk == sequencerPk, "Not sequencer");
}

circuit requireGovernor(): [] {
  const k = governorSecret();
  assert(k.is_some, "No governor secret");
  const pk = disclose(hashSignerPk(k.value, pad(32, "ascend:governor:v1")));
  assert(pk == governorPk, "Not governor");
}

circuit jubjubFrModulus(): Field {
  return 6554484396890773809930967563523245729705921265872317281365359162392183254199 as Field;
}

circuit nowBounded(): Uint<64> {
  const t = disclose(currentTime());
  assert(blockTimeGte(t), "currentTime must not exceed block time");
  assert(blockTimeLt((t + 60 as Uint<64>) as Uint<64>),
         "currentTime must be within 60s of block time"
         );
  return t;
}

circuit verifySchnorr(sig: SchnorrSignature, vk: VerifierKey, messageHash: Field): [] {
  const pubKey: JubjubPoint = constructJubjubPoint(vk.x, vk.y);
  const sG: JubjubPoint = ecMulGenerator(sig.s);
  const hAec: JubjubPoint = ecMul(pubKey, sig.h);
  const R: JubjubPoint = ecAdd(sG, hAec);
  assert(sig.rX == jubjubPointX(R), "Schnorr: R x mismatch");
  assert(sig.rY == jubjubPointY(R), "Schnorr: R y mismatch");
  const hR: Field = transientHash<Vector<2, Field>>([sig.rX, sig.rY]);
  const hA: Field = transientHash<Vector<2, Field>>([vk.x, vk.y]);
  const hFull: Field = transientHash<Vector<3, Field>>([hR, hA, messageHash]);
  const Q: Field = jubjubFrModulus();
  const qField: Field = sig.hQuotient as Field;
  const reconstructed: Field = (sig.h + qField * Q) as Field;
  assert(reconstructed == hFull, "Schnorr: challenge not bound to message");
}

circuit pickKey(c: CommitteeKeys, idx: Uint<8>): VerifierKey {
  if (idx == 0 as Uint<8>) {
    return c.slot0;
  } else if (idx == 1 as Uint<8>) {
    return c.slot1;
  } else if (idx == 2 as Uint<8>) {
    return c.slot2;
  } else if (idx == 3 as Uint<8>) {
    return c.slot3;
  } else {
    return c.slot4;
  }
}

circuit verifyCommitteeQuorum(
          sigs: Vector<3, SchnorrSignature>,
          committee: CommitteeKeys,
          messageHash: Field,
          ): [] {
  const i0 = disclose(committeeSlotChoice0());
  const i1 = disclose(committeeSlotChoice1());
  const i2 = disclose(committeeSlotChoice2());
  assert(i0 < 5 as Uint<8>, "slot0 out of range");
  assert(i1 < 5 as Uint<8>, "slot1 out of range");
  assert(i2 < 5 as Uint<8>, "slot2 out of range");
  assert(i0 != i1, "slot0 == slot1");
  assert(i0 != i2, "slot0 == slot2");
  assert(i1 != i2, "slot1 == slot2");
  verifySchnorr(sigs[0], pickKey(committee, i0), messageHash);
  verifySchnorr(sigs[1], pickKey(committee, i1), messageHash);
  verifySchnorr(sigs[2], pickKey(committee, i2), messageHash);
}

circuit assertSlotNonZero(k: VerifierKey): [] {
  assert(k.x != 0 || k.y != 0, "committee slot zero");
}

circuit assertCommitteeDistinct(c: CommitteeKeys): [] {

  assert(c.slotCount == 5 as Uint<8>, "committee slot count must be 5");
  assertSlotNonZero(c.slot0);
  assertSlotNonZero(c.slot1);
  assertSlotNonZero(c.slot2);
  assertSlotNonZero(c.slot3);
  assertSlotNonZero(c.slot4);

  assert(!(c.slot0.x == c.slot1.x && c.slot0.y == c.slot1.y), "slots 0,1 equal");
  assert(!(c.slot0.x == c.slot2.x && c.slot0.y == c.slot2.y), "slots 0,2 equal");
  assert(!(c.slot0.x == c.slot3.x && c.slot0.y == c.slot3.y), "slots 0,3 equal");
  assert(!(c.slot0.x == c.slot4.x && c.slot0.y == c.slot4.y), "slots 0,4 equal");
  assert(!(c.slot1.x == c.slot2.x && c.slot1.y == c.slot2.y), "slots 1,2 equal");
  assert(!(c.slot1.x == c.slot3.x && c.slot1.y == c.slot3.y), "slots 1,3 equal");
  assert(!(c.slot1.x == c.slot4.x && c.slot1.y == c.slot4.y), "slots 1,4 equal");
  assert(!(c.slot2.x == c.slot3.x && c.slot2.y == c.slot3.y), "slots 2,3 equal");
  assert(!(c.slot2.x == c.slot4.x && c.slot2.y == c.slot4.y), "slots 2,4 equal");
  assert(!(c.slot3.x == c.slot4.x && c.slot3.y == c.slot4.y), "slots 3,4 equal");
}

circuit assertAndBumpHwm(scopeTag: Bytes<32>, accountId: Bytes<32>, nonce: Uint<64>): [] {
  const key = disclose(persistentHash<Vector<2, Bytes<32>>>([scopeTag, accountId]));
  const current = userNonceHwm.member(key) ? userNonceHwm.lookup(key) : 0 as Uint<64>;
  assert(nonce > current, "Nonce must be strictly increasing");
  userNonceHwm.insert(key, nonce);
}

circuit assertAndBumpReceiptHwm(accountId: Bytes<32>, receiptNonce: Uint<64>): [] {
  const current = attestorReceiptHwm.member(accountId)
                    ? attestorReceiptHwm.lookup(accountId)
                    : 0 as Uint<64>;
  assert(receiptNonce > current, "Receipt nonce must be strictly increasing");
  attestorReceiptHwm.insert(accountId, receiptNonce);
}

circuit accountIdForUserKey(userPkX: Field, userPkY: Field): Bytes<32> {
  return persistentHash<Vector<3, Bytes<32>>>(
           [pad(32, "ascend:account:v1"), userPkX as Bytes<32>, userPkY as Bytes<32>,]
           );
}

circuit positionKey(accountId: Bytes<32>, marketIndex: Uint<16>): Bytes<32> {
  return persistentHash<Vector<3, Bytes<32>>>(
           [pad(32, "ascend:position"), accountId, marketIndex as Bytes<32>,]
           );
}

circuit orderKey(accountId: Bytes<32>, nonce: Uint<64>): Bytes<32> {
  return persistentHash<Vector<3, Bytes<32>>>(
           [pad(32, "ascend:order"), accountId, nonce as Bytes<32>,]
           );
}

circuit escrowMirrorStateKey(
          accountId: Bytes<32>,
          chainId: Uint<8>,
          escrowRef: Bytes<32>,
          terminalEvidenceHash: Bytes<32>,
          ): Bytes<32> {
  return persistentHash<Vector<5, Bytes<32>>>(
           [pad(32, "ascend:mirror"), accountId, chainId as Bytes<32>, escrowRef, terminalEvidenceHash,]
           );
}

circuit sourceEscrowCreditKey(chainId: Uint<8>, escrowRef: Bytes<32>): Bytes<32> {
  return persistentHash<Vector<3, Bytes<32>>>(
           [pad(32, "ascend:source-escrow"), chainId as Bytes<32>, escrowRef,]
           );
}

circuit assertSupportedSourceChain(chainId: Uint<8>): [] {
  assert(chainId == 1 as Uint<8> || chainId == 2 as Uint<8> || chainId == 3 as Uint<8>, "Unsupported source chain");
}

circuit protocolId(): Bytes<32> {
  return pad(32, "ascend:perps:v2");
}

circuit hashDomainTupleV2(
          domainBridgeDeploymentId: Bytes<32>,
          sourceChainId: Uint<8>,
          sourceContractId: Bytes<32>,
          targetChainId: Uint<8>,
          targetContractId: Bytes<32>,
          committeeEpoch: Uint<64>,
          ): Bytes<32> {
  return persistentHash<Vector<8, Bytes<32>>>(
           [pad(32, "ascend:domain-tuple:v2"),
            protocolId(),
            domainBridgeDeploymentId,
            sourceChainId as Bytes<32>,
            sourceContractId,
            targetChainId as Bytes<32>,
            targetContractId,
            committeeEpoch as Bytes<32>,]
           );
}

circuit assertCreditDomainCurrent(chainId: Uint<8>): Bytes<32> {
  assertSupportedSourceChain(chainId);
  assert(creditDomainConfigs.member(chainId), "Credit domain not set for chain");
  const cfg = creditDomainConfigs.lookup(chainId);
  assert(cfg.enabled, "Credit domain disabled");
  assert(cfg.chainId == chainId, "Credit domain chain mismatch");
  assert(cfg.sourceContractId != pad(32, ""), "source contract id missing");
  assert(cfg.targetContractId != pad(32, ""), "target contract id missing");
  assert(cfg.committeeEpoch > 0 as Uint<64>, "Committee epoch must be positive");
  const expectedDomain =
          disclose(hashDomainTupleV2(
                     bridgeDeploymentId,
                     chainId,
                     cfg.sourceContractId,
                     cfg.targetChainId,
                     cfg.targetContractId,
                     cfg.committeeEpoch,
                     ));
  assert(cfg.domain == expectedDomain, "Credit domain mismatch");
  return expectedDomain;
}

circuit notionalQuote(size: Uint<64>, price: Uint<32>): Uint<128> {
  const sizeF = size as Field;
  const priceF = price as Field;
  return (sizeF * priceF) as Uint<128>;
}

circuit assertActiveAccountCollateral(accountId: Bytes<32>, nowTs: Uint<64>): AccountCollateral {
  assert(accountCollateralCap.member(accountId), "No activated escrow collateral");
  assert(accountCollateralExpiresAt.member(accountId), "No collateral expiry");
  const cap = accountCollateralCap.lookup(accountId);
  const expiresAt = accountCollateralExpiresAt.lookup(accountId);
  assert(cap > 0 as Uint<128>, "No active collateral cap");
  assert(nowTs < expiresAt, "Escrow collateral expired");
  return AccountCollateral { cap: cap, expiresAt: expiresAt };
}

circuit addMirroredCollateral(
          accountId: Bytes<32>,
          chainId: Uint<8>,
          escrowRef: Bytes<32>,
          activatedEscrowHash: Bytes<32>,
          terminalEvidenceHash: Bytes<32>,
          cap: Uint<128>,
          expiresAt: Uint<64>,
          ): [] {
  const dChain = disclose(chainId);
  assertSupportedSourceChain(dChain);
  const dEscrowRef = disclose(escrowRef);
  assert(dEscrowRef != pad(32, ""), "Escrow ref required");
  const dActivatedEscrowHash = disclose(activatedEscrowHash);
  assert(dActivatedEscrowHash != pad(32, ""), "Activated escrow hash required");
  const dTerminalEvidenceHash = disclose(terminalEvidenceHash);
  assert(dTerminalEvidenceHash != pad(32, ""), "Terminal evidence hash required");
  const dCap = disclose(cap);
  assert(dCap > 0 as Uint<128>, "Collateral cap must be positive");
  const dExpiresAt = disclose(expiresAt);
  const nowTs = nowBounded();
  assert(nowTs < dExpiresAt, "Escrow mirror expired");
  const sourceKey = disclose(sourceEscrowCreditKey(dChain, dEscrowRef));
  assert(!creditedSourceEscrows.member(sourceKey), "Source escrow already credited");
  const mirrorKey = disclose(escrowMirrorStateKey(accountId, dChain, dEscrowRef, dTerminalEvidenceHash));
  assert(!escrowMirrors.member(mirrorKey), "Escrow mirror already active");

  const currentCap =
          accountCollateralCap.member(accountId)
            ? accountCollateralCap.lookup(accountId)
            : 0 as Uint<128>;
  const nextCap = (currentCap + dCap) as Uint<128>;
  assert(nextCap >= currentCap, "Account collateral cap overflow");
  if (accountCollateralExpiresAt.member(accountId)) {
    const currentExpiresAt = accountCollateralExpiresAt.lookup(accountId);
    assert(dExpiresAt >= currentExpiresAt, "Collateral expiry cannot move earlier");
  } else {
    accountCollateralExpiresAt.insert(accountId, dExpiresAt);
  }
  accountCollateralCap.insert(accountId, nextCap);
  creditedSourceEscrows.insert(sourceKey, true);
  escrowMirrors.insert(
    mirrorKey,
    disclose(EscrowMirror { chainId: dChain,
                            escrowRef: dEscrowRef,
                            activatedEscrowHash: dActivatedEscrowHash,
                            terminalEvidenceHash: dTerminalEvidenceHash,
                            cap: dCap,
                            expiresAt: dExpiresAt, })
    );
}

circuit addAccountUsage(accountId: Bytes<32>, amount: Uint<128>, cap: Uint<128>): [] {
  const used = accountUsedQuote.member(accountId) ? accountUsedQuote.lookup(accountId) : 0 as Uint<128>;
  const next = (used + amount) as Uint<128>;
  assert(next <= cap, "Account collateral cap exceeded");
  accountUsedQuote.insert(accountId, next);
}

circuit assertAccountUsageWithinCap(accountId: Bytes<32>, cap: Uint<128>): [] {
  const used = accountUsedQuote.member(accountId) ? accountUsedQuote.lookup(accountId) : 0 as Uint<128>;
  assert(used <= cap, "Account collateral cap below usage");
}

circuit replaceAccountPositionUsage(
          accountId: Bytes<32>,
          releaseReserved: Uint<128>,
          oldPositionQuote: Uint<128>,
          newPositionQuote: Uint<128>,
          cap: Uint<128>,
          ): [] {
  const used = accountUsedQuote.member(accountId) ? accountUsedQuote.lookup(accountId) : 0 as Uint<128>;
  const releaseTotal = (releaseReserved + oldPositionQuote) as Uint<128>;
  assert(used >= releaseTotal, "Account usage underflow");
  const remaining = (used - releaseTotal) as Uint<128>;
  const next = (remaining + newPositionQuote) as Uint<128>;
  assert(next <= cap, "Account collateral cap exceeded");
  accountUsedQuote.insert(accountId, next);
}

circuit releaseOrderUsage(accountId: Bytes<32>, orderReserved: Uint<128>): [] {
  const used = accountUsedQuote.member(accountId) ? accountUsedQuote.lookup(accountId) : 0 as Uint<128>;
  assert(used >= orderReserved, "Account usage underflow");
  accountUsedQuote.insert(accountId, disclose((used - orderReserved) as Uint<128>));
}

circuit applyFillToPosition(
          old: Position,
          fillSize: Uint<64>,
          fillPrice: Uint<32>,
          fillIsLong: Boolean,
          st: MarketState,
          ): Position {
  const fillQuote = notionalQuote(fillSize, fillPrice);
  if (old.size == 0 as Uint<64>) {
    return Position { size: fillSize,
                      isLong: fillIsLong,
                      entryPrice: fillPrice as Uint<64>,
                      entryQuote: fillQuote,
                      lastFundingIndex: st.fundingIndex,
                      lastFundingIsNeg: st.fundingIsNeg, };
  } else if (old.isLong == fillIsLong) {
    const newSize = (old.size + fillSize) as Uint<64>;
    const newQuote = (old.entryQuote + fillQuote) as Uint<128>;
    return Position { size: newSize,
                      isLong: old.isLong,
                      entryPrice: old.entryPrice,
                      entryQuote: newQuote,
                      lastFundingIndex: st.fundingIndex,
                      lastFundingIsNeg: st.fundingIsNeg, };
  } else if (fillSize <= old.size) {
    const newSize = (old.size - fillSize) as Uint<64>;
    const numF = (old.entryQuote as Field) * (newSize as Field);
    const dvRaw = reduceQuoteDiv(numF, old.size as Field);
    const dv = DivResult { q: disclose(dvRaw.q), r: disclose(dvRaw.r) };
    assert((dv.q as Field) * (old.size as Field) + (dv.r as Field) == numF, "MT-1: quotient witness mismatch");
    assert(dv.r < (old.size as Uint<128>), "MT-1: remainder out of range");
    const newQuote = newSize == 0 as Uint<64> ? 0 as Uint<128> : dv.q;
    const newEntry = newSize == 0 as Uint<64> ? 0 as Uint<64> : old.entryPrice;
    return Position { size: newSize,
                      isLong: old.isLong,
                      entryPrice: newEntry,
                      entryQuote: newQuote,
                      lastFundingIndex: st.fundingIndex,
                      lastFundingIsNeg: st.fundingIsNeg, };
  } else {
    const flipSize = (fillSize - old.size) as Uint<64>;
    const flipQuote = notionalQuote(flipSize, fillPrice);
    return Position { size: flipSize,
                      isLong: fillIsLong,
                      entryPrice: fillPrice as Uint<64>,
                      entryQuote: flipQuote,
                      lastFundingIndex: st.fundingIndex,
                      lastFundingIsNeg: st.fundingIsNeg, };
  }
}

circuit hashRegisterIntent(
          bridgeDeploymentId: Bytes<32>,
          domain: Bytes<32>,
          accountId: Bytes<32>,
          chainId: Uint<8>,
          escrowRef: Bytes<32>,
          clawbackAuthHash: Bytes<32>,
          cap: Uint<128>,
          expiresAt: Uint<64>,
          terminalEvidenceHash: Bytes<32>,
          userPkX: Field,
          userPkY: Field,
          nonce: Uint<64>,
          ): Bytes<32> {
  return persistentHash<Vector<13, Bytes<32>>>(
           [pad(32, "ascend:perps:register"),
            bridgeDeploymentId,
            domain,
            accountId,
            chainId as Bytes<32>,
            escrowRef,
            clawbackAuthHash,
            cap as Bytes<32>,
            expiresAt as Bytes<32>,
            terminalEvidenceHash,
            userPkX as Bytes<32>,
            userPkY as Bytes<32>,
            nonce as Bytes<32>,]
           );
}

circuit hashActivatedEscrowForReceipt(
          bridgeDeploymentId: Bytes<32>,
          domain: Bytes<32>,
          chainId: Uint<8>,
          escrowRef: Bytes<32>,
          clawbackAuthHash: Bytes<32>,
          cap: Uint<128>,
          expiresAt: Uint<64>,
