           [pad(32, "ascend:bridge:activated-escrow"),
            bridgeDeploymentId,
            domain,
            chainId as Bytes<32>,
            escrowRef,
            clawbackAuthHash,
            cap as Bytes<32>,
            expiresAt as Bytes<32>,
            terminalEvidenceHash,]
           );
}

circuit hashActivatedBindReceipt(
          bridgeDeploymentId: Bytes<32>,
          domain: Bytes<32>,
          accountId: Bytes<32>,
          chainId: Uint<8>,
          activatedEscrowHash: Bytes<32>,
          expiresAt: Uint<64>,
